{{ attach_library('ncids_trans/infographic') }}
{% import '@ncids_trans/content_page_macros.twig' as contentPageMacros %}
{% import '@ncids_trans/media/infographic/infographic_macros.twig' as infographicMacros %}

<!-- ********************************* BEGIN Page Content ********************************** -->
<article class="cgdp-infographic">
  <h1>{{ name }}</h1>
  {# Need styles for body content. Usa-prose condenses the width #}
  <div>
    {{ content.body }}
  </div>
  <div class="cgdpl">
    <div class="contentzone">
      {% set classes = "image-center-full" %}
      {{ infographicMacros.infographicImage(classes, content) }}
    </div>
  </div>
  <footer class="cgdp-infographic__article-footer">
    {{ contentPageMacros.ncidsDisplayDates(media,content) }}
    {% if media.field_public_use.value == '1' %}
      {{ drupal_region('public_use') }}
    {% endif %}
  </footer>
</article>
