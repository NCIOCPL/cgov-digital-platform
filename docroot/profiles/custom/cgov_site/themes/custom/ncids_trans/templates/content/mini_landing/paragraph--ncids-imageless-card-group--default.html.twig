{% set heading_classes = "cgdp-imageless-card-group__heading" %}
{% if paragraph.field_heading_visibility.value == 'sr-only' %}
  {% set heading_classes = "#{heading_classes} usa-sr-only" %}
{% endif %}
<div class="usa-section cgdp-imageless-card-group" data-eddl-landing-row>
  <div class="{{ paragraph.field_card_layout_display.value }}">
    <h2 class="{{heading_classes}}">{{ content.field_container_heading }}</h2>
    <ul>
      {{ content.field_row_cards_unlimited }}
    </ul>
  </div>
</div>
